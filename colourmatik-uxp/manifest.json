{
  "id": "com.colourmatik.panel",
  "name": "colourMatik",
  "version": "1.0.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "premierepro",
    "minVersion": "26.0"
  },
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "launchProcess": {
      "schemes": [
        "http",
        "https"
      ],
      "extensions": [
        ".app",
        ""
      ]
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "colourmatik",
      "minimumSize": { "width": 260, "height": 320 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 340, "height": 560 },
      "preferredFloatingSize": { "width": 360, "height": 640 },
      "label": { "default": "colourMatik" }
    }
  ]
}
